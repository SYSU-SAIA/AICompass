# ==========================================
# AICompass 函数计算 — 环境变量
# ==========================================
# 复制此文件为 .env 并填入真实值
# .env 已加入 .gitignore，不会提交到云端
# ==========================================

# --- API 鉴权 ---
# 前端请求需带 X-Auth-Token header，防止匿名调用
SHARED_SECRET=your-random-secret

# --- OSS 配置 ---
# OSS Bucket 所在地域（如 oss-cn-shenzhen）
OSS_REGION=oss-cn-xxxxx
# Bucket 名称
OSS_BUCKET=your-bucket-name
# 阿里云 AccessKey（用于 FC 运行时生成 OSS 上传签名）
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# --- GitHub App（替代 PAT，PR 显示为 Bot 身份）---
# 前往 https://github.com/organizations/SYSU-SAIA/settings/apps → New GitHub App
# 权限: Contents=Read & Write, Pull requests=Read & Write
# 创建后记录 App ID，下载私钥 .pem，安装到 SYSU-SAIA/AICompass
# 安装后把 URL 中 /installations/ 后面的数字填到 Installation ID
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your-private-key-content-here
-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_OWNER=SYSU-SAIA
GITHUB_REPO=AICompass
